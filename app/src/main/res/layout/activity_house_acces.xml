<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <EditText
        android:id="@+id/txtUserLogin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Login de l'invité (userLogin)"
        android:inputType="textEmailAddress"
        android:importantForAutofill="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtHouseIdInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="HouseId: -"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/txtUserLogin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Option 1 : Navigateur externe (Chrome/Safari) -->
    <Button
        android:id="@+id/btnOpenInBrowserExternal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Ouvrir la maison (Chrome/Safari)"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/txtHouseIdInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Option 2 : Dans l'app (WebView + bouton retour) -->
    <Button
        android:id="@+id/btnOpenInBrowserInApp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Ouvrir la maison (dans l'app)"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnOpenInBrowserExternal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnAddUser"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Donner accès"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnOpenInBrowserInApp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnRemoveUser"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Supprimer accès"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnAddUser"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnUsers"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Utilisateurs"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnRemoveUser"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnDevices"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Périphériques"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnUsers"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnBack"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Retour"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>