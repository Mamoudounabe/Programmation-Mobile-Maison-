<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/ic_menu_home">

    <LinearLayout
        android:layout_width="349dp"
        android:layout_height="522dp"
        android:background="#80000000"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBackHome1"
            android:layout_width="48dp"
            android:layout_height="55dp"
            android:layout_gravity="start"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_arrow_back"
            app:tint="@android:color/white"
            android:onClick="goBack"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_gravity="center">
                <TextView
                    android:id="@+id/textView4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gerer votre maison"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold"/>
                <ImageView
                    android:id="@+id/imageMaison"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_maison"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">


                <Button
                    android:id="@+id/btnGarage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#7C4DFF"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:onClick="onButtonGarageClic"
                    android:text="garage"
                    android:layout_marginBottom="8dp"
                    android:layout_marginEnd="8dp" />


                <Button
                    android:id="@+id/btnvolet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#7C4DFF"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:onClick="onButtonShuttersClic"
                    android:text="volet"
                    android:layout_marginBottom="8dp"
                    android:layout_marginEnd="8dp" />


                <Button
                    android:id="@+id/btnlumiere"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#7C4DFF"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:onClick="onButtonLightsClic"
                    android:text="lumiere"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center"
                android:layout_marginTop="24dp">


                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#7C4DFF"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:onClick="onOuvrirEtage1"
                    android:text="Ouvrir étage 1"
                    android:layout_marginEnd="8dp" />


                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#7C4DFF"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:onClick="onFermerEtage1"
                    android:text="Fermer étage 1" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center"
                android:layout_marginTop="24dp">


                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#7C4DFF"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:onClick="onOuvrirEtage2"
                    android:text="Ouvrir étage 2"
                    android:layout_marginEnd="8dp" />


                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#7C4DFF"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:onClick="onFermerEtage2"
                    android:text="Fermer étage 2" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center"
                android:layout_marginTop="24dp">


                <Button
                    android:id="@+id/btnModeJour"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#7C4DFF"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:onClick="onButtonModeJour"
                    android:text="Mode Jour"
                    android:layout_marginEnd="8dp" />


                <Button
                    android:id="@+id/btnModeNuit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#7C4DFF"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:onClick="onButtonModeNuit"
                    android:text="Mode Nuit" />
            </LinearLayout>



            <Button
                android:id="@+id/btnFunMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:background="@drawable/rounded_button"
                android:backgroundTint="#7C4DFF"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:onClick="onButtonFunModeClic"
                android:text="Mode fun"


                />


        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>